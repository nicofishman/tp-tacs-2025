generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
  directUrl = env("DATABASE_URL") 
}

model Evento {
  id                  String        @id @default(auto()) @map("_id") @db.ObjectId
  titulo              String
  descripcion         String
  fechaInicio         DateTime
  duracion            Duracion
  ubicacion           Ubicacion
  cupoMaximo          Int
  cupoMinimo          Int
  precio              Float
  estado              EstadoEvento
  categoria           Categoria    @relation(fields: [categoriaId], references: [id])
  categoriaId         String       @db.ObjectId
  organizador         Usuario      @relation("EventosOrganizados", fields: [organizadorId], references: [id])
  organizadorId       String       @db.ObjectId
  inscripciones       Inscripcion[]
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

type Duracion {
  horas Int
  minutos Int
}

type Ubicacion {
  direccion String
  lat Float
  lng Float
}


enum EstadoEvento {
  FINALIZADO
  EN_PROCESO
  CANCELADO
  PENDIENTE
}

model Categoria {   
  id                  String   @id @default(auto()) @map("_id") @db.ObjectId
  nombre              String   @unique
  eventos             Evento[]
}

model Usuario {
  id                  String    @id @default(auto()) @map("_id") @db.ObjectId
  nombre              String
  email               String    @unique
  emailVerified       Boolean   @default(false)
  rol                 RolUsuario @default(PARTICIPANTE)
  eventos             Evento[]  @relation("EventosOrganizados")
  inscripciones       Inscripcion[]
  sessions            Session[]
  accounts            Account[]

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}   

enum RolUsuario {
  ADMIN
  ORGANIZADOR
  PARTICIPANTE
}

model Inscripcion {
  id                  String    @id @default(auto()) @map("_id") @db.ObjectId
  usuario             Usuario   @relation(fields: [usuarioId], references: [id])
  usuarioId           String    @db.ObjectId
  evento              Evento    @relation(fields: [eventoId], references: [id])
  eventoId            String    @db.ObjectId
  estado              EstadoInscripcion
  fechaRegistro       DateTime  @default(now())
}


enum EstadoInscripcion {
  CONFIRMADO
  WAITLIST
  CANCELADO
}


// AUTH

model Session {
  id        String   @id @map("_id") @db.ObjectId @default(auto())
  expiresAt DateTime
  token     String
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String  @db.ObjectId
  user      Usuario     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id @map("_id") @db.ObjectId @default(auto())
  accountId             String
  providerId            String
  userId                String  @db.ObjectId
  user                  Usuario      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Verification {
  id         String    @id @map("_id") @db.ObjectId @default(auto())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}
