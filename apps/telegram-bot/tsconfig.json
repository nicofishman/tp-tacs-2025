{
  "compilerOptions": {
    "baseUrl": ".",
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "noEmit": true,
    "paths": {
      "@server/*": ["../server/src/*"],
      "@telegram-bot/*": ["../telegram-bot/src/*"]
    },
    "resolveJsonModule": true,
    "rootDirs": ["."],
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022",
    "types": ["node"],
    "verbatimModuleSyntax": true
  }
}
